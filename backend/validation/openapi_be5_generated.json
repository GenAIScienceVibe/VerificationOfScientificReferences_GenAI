          "LOOKUP_SUCCEEDED",
          "LOOKUP_FAILED",
          "METADATA_UNAVAILABLE"
        ],
        "title": "MetadataStatus"
      },
      "TextSubmissionRequest": {
        "properties": {
          "title": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 512
              },
              {
                "type": "null"
              }
            ],
            "title": "Title"
          },
          "text": {
            "type": "string",
            "title": "Text"
          }
        },
        "type": "object",
        "required": [
          "text"
        ],
        "title": "TextSubmissionRequest",
        "description": "Plain text document submission.\n\nValidation is intentionally completed in the BE-3 service so the backend can\nreturn stable project-specific error codes such as TEXT_REQUIRED and\nTEXT_TOO_SHORT instead of only framework validation messages."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }

APP_NAME="verifAI / RefCheck AI Backend"
APP_VERSION="1.0.0"
ENVIRONMENT="local"
API_PREFIX="/api/v1"
DATABASE_URL="sqlite:///./data/refcheck_be4_2.db"
CORS_ORIGINS="http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173"
LOG_LEVEL="INFO"
FILE_STORAGE_DIR="./data/uploads"
MAX_UPLOAD_SIZE_BYTES="26214400"

# Placeholder only. Do not commit real secrets.
GROQ_API_KEY=""
GROQ_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"

# Placeholder for BE-9 RAG/ML integration.
RAG_SERVICE_URL=""

# Placeholder for BE-5 metadata lookup clients.
METADATA_SERVICE_TIMEOUT_SECONDS="10"

# Local QA/debug only. Keep false for demo/public runs.
ENABLE_RAW_TEXT_DEBUG_ENDPOINT="false"
METADATA_LOOKUP_ENABLED="true"
CROSSREF_BASE_URL="https://api.crossref.org"
DOI_RESOLVER_BASE_URL="https://doi.org"
OPENALEX_BASE_URL="https://api.openalex.org"
METADATA_MAX_RETRIES="2"
CROSSREF_MAILTO=""
METADATA_USER_AGENT="verifai-refcheck-backend/1.0.0"

# BE-6 claim extraction configuration. Default local_deterministic keeps tests/demo offline.
GENAI_PROVIDER="groq"
CLAIM_EXTRACTION_MODE="local_deterministic"
CLAIM_EXTRACTION_PROMPT_VERSION="be6-claim-extraction-v1"
# BE-7 evidence package policy/version settings
EMBEDDING_MODEL_VERSION=embedding-v1
VERIFICATION_PROMPT_VERSION=verify-v1
VERIFICATION_POLICY_VERSION=policy-v1

# BE-8 verification cache policy
CACHE_ENABLED=true
CACHE_EXACT_ENABLED=true
CACHE_SEMANTIC_ENABLED=false
CACHE_HIGH_SIMILARITY_THRESHOLD=0.92
CACHE_MEDIUM_SIMILARITY_THRESHOLD=0.80
CACHE_MIN_CONFIDENCE_TO_REUSE=0.75
CACHE_TTL_DAYS=180
CACHE_REQUIRE_SAME_DOI=true
CACHE_REQUIRE_SAME_POLICY_VERSION=true
CACHE_REQUIRE_SAME_REFERENCE=false
CACHE_EVIDENCE_VERSION=evidence-v1

# BE-9 RAG/ML integration. Mock mode keeps local validation offline.
RAG_SERVICE_ENABLED=true
RAG_SERVICE_URL=http://localhost:9000
RAG_SERVICE_TIMEOUT_SECONDS=30
RAG_SERVICE_MAX_RETRIES=1
RAG_TOP_K=5
RAG_MIN_SIMILARITY_THRESHOLD=0.60
RAG_MOCK_MODE=true
RAG_REQUEST_VERSION=rag-request-v1

# BE-10 GenAI verification orchestration. Mock GenAI is used by default in this phase.
GENAI_VERIFICATION_MODE=mock
GENAI_VERIFICATION_PROMPT_VERSION=verify-v1
BE10_BASIC_SAFETY_MIN_CONFIDENCE=0.60

# BE-11 safety/confidence rules. Deterministic backend safety is primary.
SAFETY_MIN_GENAI_CONFIDENCE=0.60
SAFETY_MIN_STRONG_SIMILARITY=0.80
SAFETY_MIN_ACCEPTABLE_SIMILARITY=0.60
SAFETY_LOW_SIMILARITY_THRESHOLD=0.60
SAFETY_REQUIRE_VALID_DOI_FOR_SUPPORTED=true
SAFETY_REQUIRE_EVIDENCE_FOR_SUPPORTED=true
SAFETY_FLAG_METADATA_ONLY_SUPPORTED=true
SAFETY_FLAG_SOURCE_UNAVAILABLE=true
SAFETY_ENABLE_GENAI_RAG_CONFLICT_CHECK=true
SAFETY_MAX_CONFIDENCE_WITH_METADATA_ONLY=0.70
SAFETY_MAX_CONFIDENCE_WITH_SOURCE_UNAVAILABLE=0.40
SAFETY_MAX_CONFIDENCE_WITH_LOW_SIMILARITY=0.55
SAFETY_MAX_CONFIDENCE_WITH_PREPRINT=0.65
SAFETY_POLICY_VERSION=policy-v1

# BE-13 demo and hardening flags
DEMO_MODE=true
METADATA_MOCK_MODE=false
GENAI_MOCK_MODE=true

# BE-5 extended metadata clients (OpenAlex, Semantic Scholar, Unpaywall + PDF extraction)
SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org
UNPAYWALL_BASE_URL=https://api.unpaywall.org
# Required for Unpaywall (free, no registration — just a contact email).
UNPAYWALL_EMAIL=verifax@project.de
# PDF extraction limits (bytes and characters).
FULLTEXT_MAX_BYTES=52428800
FULLTEXT_MAX_CHARS=150000

# CORE API — full-text fallback + 4th title-search step.
# Free API key at https://core.ac.uk/services/api — 10 req/sec, no daily cap.
# When set: used as fallback after Unpaywall for full text, and as 4th stop in
# title-based DOI resolution chain (CrossRef → OpenAlex → SS → CORE).
CORE_API_KEY=your_core_api_key_here
CORE_BASE_URL=https://api.core.ac.uk/v3
